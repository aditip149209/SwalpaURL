# WackyURL Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8080
BASE_URL=http://localhost:8080
GIN_MODE=release
SERVER_REGION=us-east

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wackyurl
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=wackyurl
POSTGRES_SSLMODE=disable

# Connection Pool Settings
POSTGRES_MAX_CONNECTIONS=25
POSTGRES_MAX_IDLE_CONNECTIONS=5
POSTGRES_CONNECTION_MAX_LIFETIME=300s

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Connection Pool Settings
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# =============================================================================
# Application Configuration
# =============================================================================

# Wacky Name Generation Service (KGS)
WACKY_NAME_THRESHOLD=1000          # Refill when available names drop below this
WACKY_NAME_BATCH_SIZE=5000         # Generate this many names per batch
WACKY_REFILL_ENABLED=true          # Enable background refill worker

# Cache Configuration
CACHE_TTL=86400                    # Cache expiration in seconds (24 hours)
CACHE_ENABLED=true                 # Enable/disable Redis caching

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=info                     # Levels: debug, info, warn, error
LOG_FORMAT=json                    # Formats: json, text

# Tracing (optional - for future OpenTelemetry integration)
TRACING_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Metrics (optional - for future Prometheus integration)
METRICS_ENABLED=false
METRICS_PORT=9090

# =============================================================================
# Security & Rate Limiting (Future Implementation)
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS Configuration
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=*

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_GEO_SIMULATION=true         # Enable X-Simulated-Region header processing
ENABLE_ANALYTICS=true              # Enable click tracking
ENABLE_STATS_ENDPOINT=false        # Enable /stats/:wackyName endpoint

# =============================================================================
# Development / Testing
# =============================================================================
# ENVIRONMENT=development          # Options: development, staging, production
# DEBUG=false
